# Copy to .env and fill in. Never commit .env.

# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Telegram user ID allowed to DM the bot.
TELEGRAM_CHAT_ID=your-telegram-user-id

# Optional Telegram group ID to allow.
# TELEGRAM_GROUP_ID=-1001234567890

# Featherless API key for the reasoning and vision models.
FEATHERLESS_API_KEY=your-featherless-api-key

# Optional model overrides.
OPENCLAW_MODEL=featherless/Qwen/Qwen3-32B
OPENCLAW_VISION_MODEL=featherless/Qwen/Qwen3-VL-30B-A3B-Instruct

# Optional. Used for the private OpenClaw web UI on your tailnet.
TAILSCALE_HOSTNAME=your-pi-hostname.tail1234.ts.net

# Optional repo override if you fork ClawBee.
CLAWBEE_REPO_URL=https://github.com/mary4data/ClawBee.git
